{
	"name": "vscode-office",
	"displayName": "Office Viewer",
	"description": "Standalone Windows document viewer and editor with Office, Markdown, archive, Git history and AI assistant support.",
	"version": "0.5.6",
	"publisher": "suzike",
	"icon": "image/logo.png",
	"engines": {
		"vscode": "^1.64.0"
	},
	"keywords": [
		"pdf",
		"word",
		"docx",
		"excel",
		"xlsx",
		"csv",
		"tsv",
		"powerpoint",
		"pptx",
		"markdown",
		"epub",
		"svg",
		"psd",
		"xmind",
		"parquet",
		"zip",
		"archive",
		"font",
		"toml",
		"yaml",
		"xml",
		"git",
		"git-history"
	],
	"categories": [
		"Visualization",
		"Other"
	],
	"bugs": {
		"url": "https://github.com/suzike/Office-Viewer/issues"
	},
	"homepage": "https://github.com/suzike/Office-Viewer#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/suzike/Office-Viewer.git"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"browser": "./out/extension.web.js",
	"contributes": {
		"themes": [
			{
				"label": "One Dark Modern",
				"uiTheme": "vs-dark",
				"path": "./theme/onedark-modern.json"
			},
			{
				"label": "One Dark Modern Classic",
				"uiTheme": "vs-dark",
				"path": "./theme/onedark-modern-classic.json"
			}
		],
		"iconThemes": [
			{
				"id": "office-material-icon-theme",
				"label": "Material Icon Theme (Office Viewer)",
				"path": "./theme/material-icons.json",
				"_watch": true
			}
		],
		"languages": [
			{
				"id": "nginx",
				"aliases": [
					"NGINX Conf",
					"NGINX",
					"nginx"
				],
				"extensions": [
					".conf",
					".conf.default",
					".conf.template",
					"mime.types",
					"fastcgi_params",
					"scgi_params",
					"uwsgi_params",
					"nginx.conf",
					".nginx"
				],
				"configuration": "./syntaxes/nginx.configuration.json"
			},
			{
				"id": "kotlin",
				"aliases": [
					"Kotlin"
				],
				"extensions": [
					".kt",
					".kts"
				],
				"configuration": "./syntaxes/kotlin-language-configuration.json"
			},
			{
				"id": "reg",
				"aliases": [
					"REG",
					"reg"
				],
				"extensions": [
					".reg",
					".REG"
				],
				"configuration": "./syntaxes/reg-language-configuration.json"
			},
			{
				"id": "http",
				"aliases": [
					"HTTP",
					"Http",
					"http"
				],
				"extensions": [
					".http",
					".rest"
				],
				"firstLine": "^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE)\\s+(.*?)HTTP/[0-9\\.]+$",
				"configuration": "./syntaxes/http-language-configuration.json"
			},
			{
				"id": "toml",
				"aliases": [
					"TOML",
					"Toml",
					"toml"
				],
				"extensions": [
					".toml"
				],
				"configuration": "./syntaxes/toml-language-configuration.json"
			},
			{
				"id": "kusto",
				"aliases": [
					"Kusto",
					"kusto",
					"KQL",
					"kql"
				],
				"extensions": [
					".csl",
					".kusto",
					".kql"
				],
				"configuration": "./syntaxes/kusto-language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "nginx",
				"scopeName": "source.nginx",
				"path": "./syntaxes/nginx.tmLanguage",
				"embeddedLanguages": {
					"meta.embedded.block.lua": "lua"
				}
			},
			{
				"language": "kotlin",
				"scopeName": "source.kotlin",
				"path": "./syntaxes/kotlin.tmLanguage.json"
			},
			{
				"language": "reg",
				"scopeName": "source.reg",
				"path": "./syntaxes/reg.tmLanguage"
			},
			{
				"language": "http",
				"scopeName": "source.http",
				"path": "./syntaxes/http.tmLanguage.json"
			},
			{
				"language": "toml",
				"scopeName": "source.toml",
				"path": "./syntaxes/toml.tmLanguage.json"
			},
			{
				"language": "kusto",
				"scopeName": "source.kusto",
				"path": "./syntaxes/kusto.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "http",
				"path": "./snippets/http.json"
			}
		],
		"commands": [
			{
				"command": "vscode-office.save-response-body",
				"title": "Save Response",
				"icon": "$(save)",
				"enablement": "!office.extensionHost.web"
			},
			{
				"command": "vscode-office.copy-response-body",
				"title": "Copy Response",
				"icon": "$(copy)",
				"enablement": "!office.extensionHost.web"
			},
			{
				"command": "office.markdown.switch",
				"title": "Switch markdown editor",
				"icon": "$(edit)"
			},
			{
				"command": "office.csv.switch",
				"title": "Switch CSV editor",
				"icon": "$(edit)"
			},
			{
				"command": "office.markdown.paste",
				"title": "Enhance paste in markdown",
				"enablement": "!office.extensionHost.web"
			},
			{
				"command": "office.html.preview",
				"title": "Preview HTML"
			},
			{
				"command": "office.gitHistory.view",
				"title": "View Git History",
				"icon": "$(history)",
				"enablement": "!office.extensionHost.web"
			},
			{
				"command": "office.gitHistory.viewFileHistory",
				"title": "Git: View File History",
				"icon": "$(git-commit)",
				"enablement": "!office.extensionHost.web"
			},
			{
				"command": "office.gitHistory.quickSync",
				"title": "Git: Quick Sync",
				"icon": "$(sync)",
				"enablement": "!office.extensionHost.web"
			}
		],
		"keybindings": [
			{
				"command": "office.markdown.paste",
				"key": "ctrl+v",
				"mac": "cmd+v",
				"when": "editorTextFocus && resourceLangId == markdown && !office.extensionHost.web"
			},
			{
				"command": "office.html.preview",
				"key": "ctrl+shift+v",
				"when": "editorTextFocus && editorLangId == html"
			},
			{
				"command": "office.markdown.switch",
				"key": "ctrl+alt+e",
				"mac": "ctrl+cmd+e",
				"when": "editorTextFocus && editorLangId == markdown"
			},
			{
				"command": "vscode-office.request",
				"key": "ctrl+enter",
				"mac": "cmd+enter",
				"when": "editorTextFocus && editorLangId == 'http' && !office.extensionHost.web"
			}
		],
		"menus": {
			"scm/title": [
				{
					"command": "office.gitHistory.view",
					"group": "navigation",
					"when": "scmProvider == git && !office.extensionHost.web"
				},
				{
					"command": "office.gitHistory.quickSync",
					"group": "navigation",
					"when": "scmProvider == git && config.vscode-office.gitHistory.quickSyncButton && !office.extensionHost.web"
				}
			],
			"scm/repository": [
				{
					"command": "office.gitHistory.view",
					"group": "navigation",
					"when": "scmProvider == git && !office.extensionHost.web"
				}
			],
			"scm/resourceState/context": [
				{
					"command": "office.gitHistory.viewFileHistory",
					"when": "config.git.enabled && gitOpenRepositoryCount != 0 && !office.extensionHost.web"
				}
			],
			"editor/title": [
				{
					"command": "office.gitHistory.viewFileHistory",
					"group": "navigation@4",
					"when": "config.git.enabled && gitOpenRepositoryCount != 0 && resourceScheme == file && !office.extensionHost.web"
				},
				{
					"command": "office.markdown.switch",
					"when": "resourceExtname == '.md'",
					"group": "navigation@-2"
				},
				{
					"command": "office.csv.switch",
					"when": "resourceExtname == '.csv' || resourceExtname == '.tsv'",
					"group": "navigation@-2"
				},
				{
					"when": "editorTextFocus && resourceScheme == rest-client-response",
					"command": "vscode-office.copy-response-body",
					"group": "navigation@0"
				},
				{
					"when": "editorTextFocus && resourceScheme == rest-client-response",
					"command": "vscode-office.save-response-body",
					"group": "navigation@2"
				}
			],
			"editor/context": [
				{
					"command": "office.gitHistory.viewFileHistory",
					"group": "git",
					"when": "config.git.enabled && gitOpenRepositoryCount != 0 && resourceScheme == file && !office.extensionHost.web"
				},
				{
					"command": "office.html.preview",
					"group": "navigation@1",
					"when": "editorTextFocus && editorLangId == html"
				},
				{
					"command": "vscode-office.save-response-body",
					"group": "http@2",
					"when": "editorTextFocus && resourceScheme == rest-client-response && !office.extensionHost.web"
				},
				{
					"command": "vscode-office.copy-response-body",
					"group": "http@4",
					"when": "editorTextFocus && resourceScheme == rest-client-response && !office.extensionHost.web"
				}
			],
			"explorer/context": [
				{
					"command": "office.gitHistory.viewFileHistory",
					"group": "git",
					"when": "config.git.enabled && gitOpenRepositoryCount != 0 && resourceScheme == file && !office.extensionHost.web"
				}
			]
		},
		"customEditors": [
			{
				"viewType": "cweijan.officeViewer",
				"displayName": "Office Viewer",
				"selector": [
					{
						"filenamePattern": "*.xls"
					},
					{
						"filenamePattern": "*.xlsx"
					},
					{
						"filenamePattern": "*.xlsm"
					},
					{
						"filenamePattern": "file:/**/*.csv"
					},
					{
						"filenamePattern": "vscode-vfs:/**/*.csv"
					},
					{
						"filenamePattern": "vscode-remote:/**/*.csv"
					},
					{
						"filenamePattern": "*.tsv"
					},
					{
						"filenamePattern": "*.ods"
					},
					{
						"filenamePattern": "file:/**/*.docx"
					},
					{
						"filenamePattern": "vscode-vfs:/**/*.docx"
					},
					{
						"filenamePattern": "vscode-remote:/**/*.docx"
					},
					{
						"filenamePattern": "*.dotx"
					},
					{
						"filenamePattern": "*.pptx"
					},
					{
						"filenamePattern": "*.pptm"
					},
					{
						"filenamePattern": "*.pdf"
					},
					{
						"filenamePattern": "*.epub"
					},
					{
						"filenamePattern": "*.ttf"
					},
					{
						"filenamePattern": "*.woff"
					},
					{
						"filenamePattern": "*.woff2"
					},
					{
						"filenamePattern": "*.otf"
					},
					{
						"filenamePattern": "*.svg"
					},
					{
						"filenamePattern": "*.icns"
					},
					{
						"filenamePattern": "*.psd"
					},
					{
						"filenamePattern": "*.xmind"
					},
					{
						"filenamePattern": "*.tiff"
					},
					{
						"filenamePattern": "*.tif"
					},
					{
						"filenamePattern": "*.heif"
					},
					{
						"filenamePattern": "*.heic"
					}
				]
			},
			{
				"viewType": "cweijan.archiveViewer",
				"displayName": "Archive Viewer",
				"selector": [
					{
						"filenamePattern": "*.jar"
					},
					{
						"filenamePattern": "*.zip"
					},
					{
						"filenamePattern": "*.7z"
					},
					{
						"filenamePattern": "*.rar"
					},
					{
						"filenamePattern": "*.tar.gz"
					},
					{
						"filenamePattern": "*.tgz"
					},
					{
						"filenamePattern": "*.tar"
					},
					{
						"filenamePattern": "*.apk"
					},
					{
						"filenamePattern": "*.vsix"
					},
					{
						"filenamePattern": "*.crx"
					}
				]
			},
			{
				"viewType": "cweijan.imageViewer",
				"displayName": "Image Preview (Office Viewer)",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.jpg"
					},
					{
						"filenamePattern": "*.png"
					},
					{
						"filenamePattern": "*.gif"
					},
					{
						"filenamePattern": "*.apng"
					},
					{
						"filenamePattern": "*.apng"
					},
					{
						"filenamePattern": "*.bmp"
					},
					{
						"filenamePattern": "*.ico"
					},
					{
						"filenamePattern": "*.cur"
					},
					{
						"filenamePattern": "*.jpeg"
					},
					{
						"filenamePattern": "*.pjpeg"
					},
					{
						"filenamePattern": "*.pjp"
					},
					{
						"filenamePattern": "*.webp"
					}
				]
			},
			{
				"viewType": "cweijan.markdownViewer",
				"displayName": "Markdown Editor",
				"selector": [
					{
						"filenamePattern": "file:/**/*.md"
					},
					{
						"filenamePattern": "file:/**/*.markdown"
					},
					{
						"filenamePattern": "vscode-vfs:/**/*.md"
					},
					{
						"filenamePattern": "vscode-vfs:/**/*.markdown"
					},
					{
						"filenamePattern": "vscode-remote:/**/*.md"
					},
					{
						"filenamePattern": "vscode-remote:/**/*.markdown"
					}
				]
			},
			{
				"viewType": "cweijan.htmlViewer",
				"displayName": "Html Viewer",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.htm"
					},
					{
						"filenamePattern": "*.html"
					},
					{
						"filenamePattern": "*.xhtml"
					}
				]
			},
			{
				"viewType": "cweijan.parquetViewer",
				"displayName": "Parquet Viewer",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.parquet"
					}
				]
			},
			{
				"viewType": "cweijan.classViewer",
				"displayName": "Java Decompiler",
				"selector": [
					{
						"filenamePattern": "file:/**/*.class"
					}
				]
			}
		],
		"configuration": [
			{
				"title": "Git History",
				"order": 98,
				"properties": {
					"vscode-office.gitHistory.quickSyncButton": {
						"type": "boolean",
						"default": false,
						"description": "Show Quick Sync button in Source Control (Git) title toolbar."
					}
				}
			},
			{
				"title": "Markdown",
				"order": 1,
				"properties": {
					"vscode-office.editorTheme": {
						"type": "string",
						"enum": [
							"Auto",
							"Light",
							"Solarized",
							"Warm Light",
							"Dim Light",
							"One Dark",
							"Github Dark",
							"Nord",
							"Monokai",
							"Dracula"
						],
						"default": "Auto",
						"markdownDescription": "The theme for the Markdown editor."
					},
					"vscode-office.codeMirrorTheme": {
						"type": "string",
						"enum": [
							"Auto",
							"Github",
							"Solarized Light",
							"Material Light",
							"Quiet Light",
							"One Light",
							"Dracula",
							"Monokai",
							"One Dark",
							"Solarized Dark",
							"Material Dark"
						],
						"default": "Auto",
						"markdownDescription": "CodeMirror syntax theme for code blocks in the Markdown editor."
					},
					"vscode-office.mermaidTheme": {
						"type": "string",
						"enum": [
							"Auto",
							"Light",
							"Forest",
							"Ocean",
							"Sunset",
							"Dark",
							"Dracula",
							"Monokai",
							"Nord"
						],
						"default": "Auto",
						"markdownDescription": "Mermaid diagram theme in the Markdown editor. Auto follows the editor theme."
					},
					"vscode-office.editMode": {
						"type": "string",
						"enum": [
							"wysiwyg",
							"ir"
						],
						"default": "wysiwyg",
						"markdownDescription": "Default edit mode for the Markdown editor."
					},
					"vscode-office.workspacePathAsImageBasePath": {
						"type": "boolean",
						"default": false,
						"description": "Using workspace path as markdown image base path."
					},
					"vscode-office.pasterImgPath": {
						"type": "string",
						"default": "image/${fileName}/${now}.${ext}",
						"description": "Markdown paste image path, variables: workspaceDir, fileName, now, date (YYYYMMDD), uuid, ext (file extension)."
					}
				}
			},
			{
				"title": "Markdown PDF",
				"order": 2,
				"properties": {
					"vscode-office.chromiumPath": {
						"type": "string",
						"description": "Set the chromium browser location for exporting markdown pdf."
					},
					"vscode-office.puppeteerArgs": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"default": [],
						"description": "Additional arguments to pass to Puppeteer/Chromium when exporting PDF. Example: [\"--no-sandbox\", \"--disable-setuid-sandbox\"] for Linux servers running as root."
					},
					"vscode-office.pdfMarginTop": {
						"type": "integer",
						"default": 25,
						"description": "Printed pdf default top margin."
					}
				}
			},
			{
				"title": "HTTP Client",
				"order": 3,
				"properties": {
					"vscode-office.followredirect": {
						"type": "boolean",
						"default": true,
						"scope": "resource",
						"description": "Follow HTTP 3xx responses as redirects."
					},
					"vscode-office.environmentVariables": {
						"type": "object",
						"default": {
							"$shared": {}
						},
						"scope": "resource",
						"markdownDescription": "Sets the environments and custom variables belongs to it."
					},
					"vscode-office.previewOption": {
						"type": "string",
						"enum": [
							"full",
							"headers",
							"body",
							"exchange"
						],
						"default": "body",
						"scope": "resource",
						"description": "Response preview output option"
					},
					"vscode-office.previewColumn": {
						"type": "string",
						"enum": [
							"current",
							"beside"
						],
						"default": "beside",
						"scope": "resource",
						"description": "Response preview column option"
					},
					"vscode-office.formParamEncodingStrategy": {
						"type": "string",
						"enum": [
							"automatic",
							"never",
							"always"
						],
						"default": "automatic",
						"scope": "resource",
						"description": "Form param encoding strategy for x-www-form-urlencoded body"
					},
					"vscode-office.addRequestBodyLineIndentationAroundBrackets": {
						"type": "boolean",
						"default": true,
						"scope": "resource",
						"description": "Add line indentation around brackets in request body"
					},
					"vscode-office.decodeEscapedUnicodeCharacters": {
						"type": "boolean",
						"default": false,
						"scope": "resource",
						"description": "Decode escaped unicode characters in response body."
					},
					"vscode-office.logLevel": {
						"type": "string",
						"enum": [
							"error",
							"warn",
							"info",
							"verbose"
						],
						"default": "error",
						"scope": "resource",
						"description": "The verbosity of logging in the REST output panel"
					},
					"vscode-office.enableCustomVariableReferencesCodeLens": {
						"type": "boolean",
						"default": true,
						"scope": "resource",
						"description": "Enable custom variable references CodeLens in request file"
					}
				}
			},
			{
				"title": "Telemetry",
				"order": 99,
				"properties": {
					"vscode-office.enableTelemetry": {
						"type": "boolean",
						"default": true,
						"tags": [
							"telemetry",
							"usesOnlineServices"
						],
						"markdownDescription": "Enable anonymous usage data collection to help improve Office Viewer. This respects VS Code global telemetry settings (`#telemetry.telemetryLevel#`)."
					}
				}
			}
		]
	},
	"scripts": {
		"dev": "vite --mode=development",
		"dev:web": "OFFICE_EXTENSION_TARGET=web vite --mode=development",
		"desktop:typecheck": "tsc -p tsconfig.desktop.json --noEmit",
		"desktop:build:host": "tsc -p tsconfig.desktop.json",
		"desktop:build:renderer": "vite build --config vite.desktop.config.ts --mode production",
		"desktop:build": "npm run build && npm run desktop:build:renderer && npm run desktop:build:host",
		"benchmark:desktop": "npm run desktop:build && node scripts/performance/run-desktop-benchmark.mjs",
		"benchmark:desktop:check": "npm run desktop:build && node scripts/performance/run-desktop-benchmark.mjs --enforce",
		"desktop:dev": "npm run desktop:build:host && concurrently -k -n renderer,host,app \"vite --config vite.desktop.config.ts --mode development\" \"tsc -p tsconfig.desktop.json --watch --preserveWatchOutput\" \"wait-on http://127.0.0.1:5740/index.desktop.html && cross-env OFFICE_DESKTOP_DEV_URL=http://127.0.0.1:5740/index.desktop.html electron out/desktop/main/index.js\"",
		"desktop:dist": "npm run desktop:build && electron-builder --win nsis portable",
		"test:desktop:unit": "node --test --test-concurrency=1 test/desktop/bounded-lru-cache.test.mjs test/desktop/file-session-manager.test.mjs test/desktop/archive-service.test.mjs test/desktop/nonzip-archive-service.test.mjs test/desktop/java-decompiler-service.test.mjs test/desktop/http-service.test.mjs test/desktop/http-language.test.mjs test/desktop/http-settings-service.test.mjs test/desktop/git-history-service.test.mjs test/desktop/html-inspector-script.test.mjs test/desktop/html-validate.test.mjs test/desktop/text-language.test.mjs test/desktop/markdown-settings-service.test.mjs test/desktop/markdown-secret-guard.test.mjs test/desktop/markdown-image-service.test.mjs test/desktop/markdown-ai-service.test.mjs test/desktop/markdown-export-service.test.mjs test/desktop/markdown-plain-text.test.mjs test/desktop/markdown-drop-links.test.mjs test/desktop/markdown-link-scanner.test.mjs test/desktop/markdown-template-service.test.mjs test/desktop/sensitive-data.test.mjs test/desktop/ai-assistant-settings-service.test.mjs test/desktop/ai-document-context-service.test.mjs test/desktop/ai-assistant-service.test.mjs test/desktop/ai-cli-adapter.test.mjs",
		"test:desktop:e2e": "node --test --test-concurrency=1 test/desktop/electron-xlsx.e2e.test.mjs test/desktop/electron-spreadsheet-formats.e2e.test.mjs test/desktop/electron-word-powerpoint.e2e.test.mjs test/desktop/electron-xmind-epub.e2e.test.mjs test/desktop/electron-image-svg.e2e.test.mjs test/desktop/electron-image-formats.e2e.test.mjs test/desktop/electron-parquet-psd-font-icns.e2e.test.mjs test/desktop/electron-zip.e2e.test.mjs test/desktop/electron-nonzip-archive.e2e.test.mjs test/desktop/electron-pdf.e2e.test.mjs test/desktop/electron-html.e2e.test.mjs test/desktop/electron-markdown.e2e.test.mjs test/desktop/electron-http.e2e.test.mjs test/desktop/electron-git-history.e2e.test.mjs test/desktop/electron-text-languages.e2e.test.mjs test/desktop/electron-ai-assistant.e2e.test.mjs",
		"test:desktop:packaged": "cross-env \"OFFICE_VIEWER_PACKAGED_EXECUTABLE=dist/desktop/win-unpacked/Office Viewer.exe\" node --test test/desktop/electron-xlsx.e2e.test.mjs",
		"test:desktop": "npm run desktop:build && npm run test:desktop:unit && npm run test:desktop:e2e",
		"lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
		"build": "vite build --mode=production",
		"package": "vsce package --no-dependencies",
		"publish": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
		"vscode:prepublish": "npm run build"
	},
