	"build": {
		"appId": "com.officeviewer.desktop",
		"productName": "Office Viewer",
		"asar": true,
		"asarUnpack": [
			"resource/java-decompiler.jar"
		],
		"directories": {
			"output": "dist/desktop"
		},
		"files": [
			"out/desktop/**/*",
			"out/desktop-renderer/**/*",
			"resource/**/*",
			"template/**/*",
			"image/logo.png",
			"LICENSE",
			"package.json"
		],
		"extraMetadata": {
			"main": "out/desktop/main/index.js"
		},
		"win": {
			"icon": "image/logo.png",
			"target": [
				{
					"target": "nsis",
					"arch": [
